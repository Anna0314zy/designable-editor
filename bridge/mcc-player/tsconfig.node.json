{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".", 
    "paths": {
      "@/*": ["./src/*"], // '@' 指向 'src' 目录
    },
  },
  "include": ["vite.config.ts"]
}
