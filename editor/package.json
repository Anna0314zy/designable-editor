{
  "name": "play",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "copyFontToPublic": "node ./scripts/fonts.js",
    "dev": "pnpm copyFontToPublic && vite --mode dev",
    "build": "pnpm install && vite build --mode test",
    "build:prod": "pnpm install && vite build --mode prod",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "hotUpdate:test": "node ./scripts/release/release.cjs --mode test",
    "release:test": "pnpm install && node ./scripts/release/setVersion.cjs && npm run build && npm run hotUpdate:test",
    "update": "node ./scripts/release/setVersion.cjs --mode test"
  },
  "dependencies": {
    "@editor/core": "workspace:^1.0.0",
    "@editor/react": "workspace:^1.0.0",
    "@editor/react-sandbox": "workspace:^1.0.0",
    "@editor/react-settings-form": "workspace:^1.0.0",
    "@editor/typing": "workspace:^",
    "@ld/slide-editor": "workspace:^",
    "@monaco-editor/loader": "^1.7.0",
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@play/render": "workspace:^1.0.0",
    "@sentry/react": "^7.93.0",
    "@slide/fonts": "workspace:^1.0.0",
    "@slide/render-components": "workspace:^1.0.0",
    "@slide/slide-shape": "workspace:^1.0.0",
    "@slides/antd": "npm:@formily/antd-v5@^1.2.4",
    "@slides/react": "npm:@formily/react@^2.3.4",
    "@slides/reactive-react": "npm:@formily/reactive-react@^2.3.4",
    "@vitejs/plugin-react": "^4.0.4",
    "cos-js-sdk-v5": "^1.10.1",
    "hotkeys-js": "^4.0.4",
    "hox": "^2.1.1",
    "immer": "^10.2.0",
    "less": "^4.2.0",
    "nanoid": "^5.0.3",
    "post-me": "^0.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-moveable": "^0.55.0",
    "uuid": "^9.0.1",
    "vite-plugin-build": "^0.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.5.9",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-basic-ssl": "^1.0.1",
    "@vitejs/plugin-react-swc": "^3.3.2",
    "cos-nodejs-sdk-v5": "^2.12.6",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "inquirer": "^9.2.15",
    "minimist": "^1.2.8",
    "typescript": "^5.0.2",
    "vite": "^4.4.5",
    "vite-plugin-pwa": "^0.17.4",
    "workbox-window": "^7.0.0"
  }
}
